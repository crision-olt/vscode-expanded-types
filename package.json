{
  "name": "expanded-types",
  "displayName": "Expanded Types",
  "description": "Deep-expand TypeScript types in hover tooltips",
  "version": "0.0.1",
  "publisher": "crision-olt",
  "repository": {
    "type": "git",
    "url": "https://github.com/crision-olt/vscode-expanded-types"
  },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other", "Programming Languages"],
  "keywords": ["typescript", "types", "hover", "expand", "developer tools"],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact"
  ],
  "contributes": {
    "typescriptServerPlugins": [
      {
        "name": "expanded-types-plugin",
        "enableForWorkspaceTypeScriptVersions": true
      }
    ],
    "commands": [
      {
        "command": "expandedTypes.toggle",
        "title": "Expanded Types: Toggle"
      },
      {
        "command": "expandedTypes.copyAtCursor",
        "title": "Expanded Types: Copy Expanded Type at Cursor"
      }
    ],
    "keybindings": [
      {
        "command": "expandedTypes.toggle",
        "key": "ctrl+alt+e",
        "mac": "ctrl+alt+e"
      }
    ],
    "configuration": {
      "title": "Expanded Types",
      "properties": {
        "expandedTypes.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Whether expanded type display is active. Persisted across reloads."
        },
        "expandedTypes.maxDepth": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 20,
          "description": "Maximum recursion depth when expanding types. Higher values expand more but may be slow on complex types."
        },
        "expandedTypes.keepOriginalDocs": {
          "type": "boolean",
          "default": true,
          "description": "Show original JSDoc documentation above the expanded type block."
        }
      }
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
