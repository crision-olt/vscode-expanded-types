{
  "name": "expanded-types",
  "displayName": "Expanded Types",
  "description": "Deep-expand TypeScript types in hover tooltips",
  "version": "0.0.1",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "main": "./out/extension.js",
  "typescriptServerPlugins": [
    {
      "name": "./out/plugin",
      "enableForWorkspaceTypeScriptVersions": true
    }
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "contributes": {
    "commands": [
      {
        "command": "expandedTypes.toggle",
        "title": "Expanded Types: Toggle"
      }
    ],
    "keybindings": [
      {
        "command": "expandedTypes.toggle",
        "key": "ctrl+alt+e",
        "mac": "ctrl+alt+e"
      }
    ]
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
